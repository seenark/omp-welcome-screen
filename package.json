{
    "name": "@codesook/pi-welcome-screen",
    "version": "0.4.0",
    "description": "Customizable animated ASCII art welcome overlay for Oh-My-Pi — shows on session start with countdown and auto-dismiss",
    "type": "module",
    "files": [
        "src/",
        "README.md",
        "AGENTS.md"
    ],
    "keywords": [
        "pi-package",
        "pi",
        "omp",
        "oh-my-pi",
        "coding-agent",
        "welcome",
        "ascii",
        "extension"
    ],
    "author": "Code Sook",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/seenark/pi-welcome-screen.git"
    },
    "scripts": {
        "build": "echo 'No build needed — Pi loads TypeScript extensions via jiti'",
        "test": "bun test",
        "release": "npm publish --access public"
    },
    "peerDependencies": {
        "@oh-my-pi/pi-coding-agent": "*",
        "@oh-my-pi/pi-tui": "*"
    },
    "dependencies": {
        "@oh-my-pi/pi-utils": "*",
        "@xterm/headless": "^6.0.0"
    },
    "omp": {
        "extensions": [
            "./src/index.ts"
        ]
    },
    "pi": {
        "extensions": [
            "./src/index.ts"
        ]
    }
}
